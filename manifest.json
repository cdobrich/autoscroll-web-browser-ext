{
  "manifest_version": 3,
  "name": "Multi-Directional Autoscroll",
  "version": "1.0",
  "description": "Enables middle-click multi-directional scrolling.",
  "permissions": [],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}