{
  "manifest_version": 3,
  "name": "Multi-Directional Autoscroll",
  "version": "1.1",
  "description": "Enables middle-click multi-directional scrolling with custom settings.",
  "permissions": ["storage"],
  "options_ui": {
    "page": "options.html",
    "open_in_tab": false
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
